# --- API (NestJS) ---
PORT=3001
WEB_ORIGIN=http://localhost:3000
# Chemin optionnel vers le catalogue REEL (confidentiel, hors depot).
# Si absent, l'app utilise l'echantillon anonymise versionne.
CATALOG_PATH=

# --- Web (Next.js) ---
NEXT_PUBLIC_API_URL=http://localhost:3001

# --- Mobile (Expo Go) ---
# Pour scanner le QR depuis un telephone physique avec Docker Compose,
# mettre l'adresse IP locale de votre machine, par exemple 192.168.1.42.
REACT_NATIVE_PACKAGER_HOSTNAME=localhost

# --- Strava OAuth (iteration suivante) ---
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REDIRECT_URI=http://localhost:3001/api/auth/strava/callback

# --- Base de donnees (Postgres, iteration suivante) ---
DATABASE_URL=postgresql://mtw:mtw@localhost:5432/mtw
