# --- API (NestJS) ---
PORT=3001
WEB_ORIGIN=http://localhost:3000
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
# Secret serveur uniquement. Ne jamais exposer dans web/mobile.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_or_legacy_service_role_xxx
# Chemin optionnel vers le catalogue REEL (confidentiel, hors depot).
# Si absent, l'app utilise l'echantillon anonymise versionne.
CATALOG_PATH=

# --- Web (Next.js) ---
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# --- Mobile (Expo Go) ---
EXPO_PUBLIC_API_URL=http://localhost:3001
EXPO_PUBLIC_WEB_URL=http://localhost:3000
EXPO_PUBLIC_WEB_AUTH_CALLBACK_URL=http://localhost:3000/auth/callback
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
# Pour scanner le QR depuis un telephone physique avec Docker Compose,
# mettre l'adresse IP locale de votre machine, par exemple :
# EXPO_PUBLIC_API_URL=http://192.168.1.42:3001
# EXPO_PUBLIC_WEB_URL=http://192.168.1.42:3000
# EXPO_PUBLIC_WEB_AUTH_CALLBACK_URL=http://192.168.1.42:3000/auth/callback
# Android Emulator utilise 10.0.2.2 pour joindre la machine hote :
# EXPO_PUBLIC_API_URL=http://10.0.2.2:3001
# EXPO_PUBLIC_WEB_URL=http://10.0.2.2:3000
# EXPO_PUBLIC_WEB_AUTH_CALLBACK_URL=http://10.0.2.2:3000/auth/callback
# iOS Simulator peut garder localhost.
REACT_NATIVE_PACKAGER_HOSTNAME=localhost

# --- Strava OAuth 2.0 (pont backend, comme Garmin) ---
# Identifiants de l'application Strava (https://www.strava.com/settings/api).
# Strava n'est PAS un provider OIDC : le flux est pilote cote API NestJS, pas via
# le custom provider Supabase. Dans le dashboard Strava, "Authorization Callback
# Domain" doit correspondre a l'hote du redirect_uri ci-dessous (ex: localhost).
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REDIRECT_URI=http://localhost:3001/api/auth/strava/callback
# Scopes Strava (liste separee par des virgules). Defaut: read,activity:read_all
# STRAVA_SCOPES=read,activity:read_all

# --- Garmin OAuth 2.0 (PKCE, via Garmin Connect Developer Program) ---
# Identifiants obtenus sur https://developer.garmin.com (Consumer Key/Secret).
GARMIN_CLIENT_ID=
GARMIN_CLIENT_SECRET=
# URL publique de l'API joignable depuis le navigateur du telephone (LAN IP si
# Expo Go sur device physique). Sert a construire le redirect_uri Garmin.
API_PUBLIC_URL=http://localhost:3001
# redirect_uri enregistre dans le dashboard Garmin (doit correspondre exactement).
# Par defaut: ${API_PUBLIC_URL}/api/auth/garmin/callback
GARMIN_REDIRECT_URI=http://localhost:3001/api/auth/garmin/callback
# Endpoints surchargeables si Garmin fait evoluer ses URLs.
# GARMIN_AUTHORIZE_URL=https://connect.garmin.com/oauth2Confirm
# GARMIN_TOKEN_URL=https://diauth.garmin.com/di-oauth2-service/oauth/token
# GARMIN_USER_API_URL=https://apis.garmin.com/wellness-api/rest/user/id

# --- Base de donnees (Postgres, iteration suivante) ---
DATABASE_URL=postgresql://mtw:mtw@localhost:5432/mtw
